<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Siparişler – Admin</title>
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@600;700&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
    <style>
        :root {
            --primary: #c026d3; --primary-dark: #86198f; --primary-light: #f0abfc;
            --accent: #7c3aed; --bg: #0f0a1a; --surface: #1a1028; --surface2: #231535;
            --border: #2e1f42; --text: #f3e8ff; --text-muted: #a78bca;
            --success: #10b981; --danger: #ef4444; --warning: #f59e0b; --info: #3b82f6;
        }
        * { margin:0; padding:0; box-sizing:border-box; }
        body { font-family:'DM Sans',sans-serif; background:var(--bg); color:var(--text); display:flex; min-height:100vh; }

        /* Sidebar */
        .sidebar { width:260px; background:var(--surface); border-right:1px solid var(--border); display:flex; flex-direction:column; position:fixed; top:0; left:0; height:100vh; z-index:100; }
        .sidebar-logo { padding:28px 24px; border-bottom:1px solid var(--border); display:flex; align-items:center; gap:12px; }
        .sidebar-logo .icon { width:38px; height:38px; background:linear-gradient(135deg,var(--primary),var(--accent)); border-radius:10px; display:flex; align-items:center; justify-content:center; font-size:18px; }
        .sidebar-logo span { font-family:'Playfair Display',serif; font-size:17px; font-weight:700; background:linear-gradient(90deg,var(--primary-light),#e879f9); -webkit-background-clip:text; -webkit-text-fill-color:transparent; }
        .sidebar-nav { flex:1; padding:20px 12px; overflow-y:auto; }
        .nav-label { font-size:10px; font-weight:600; letter-spacing:1.5px; text-transform:uppercase; color:var(--text-muted); padding:8px 12px 6px; }
        .nav-item { display:flex; align-items:center; gap:12px; padding:11px 14px; border-radius:10px; text-decoration:none; color:var(--text-muted); font-size:14px; font-weight:500; margin-bottom:3px; transition:all 0.2s; }
        .nav-item:hover { background:var(--surface2); color:var(--text); }
        .nav-item.active { background:linear-gradient(90deg,rgba(192,38,211,0.2),rgba(124,58,237,0.1)); color:var(--primary-light); border-left:3px solid var(--primary); }
        .nav-item i { width:18px; text-align:center; }
        .badge-pill { margin-left:auto; background:var(--primary); color:#fff; font-size:10px; font-weight:700; padding:2px 7px; border-radius:20px; }
        .sidebar-footer { padding:16px 12px; border-top:1px solid var(--border); }

        /* Main */
        .main { margin-left:260px; flex:1; display:flex; flex-direction:column; }
        .topbar { background:var(--surface); border-bottom:1px solid var(--border); padding:16px 32px; display:flex; align-items:center; justify-content:space-between; position:sticky; top:0; z-index:90; }
        .topbar h1 { font-family:'Playfair Display',serif; font-size:22px; font-weight:700; }
        .topbar-right { display:flex; align-items:center; gap:16px; }
        .topbar-btn { width:38px; height:38px; background:var(--surface2); border:1px solid var(--border); border-radius:10px; display:flex; align-items:center; justify-content:center; color:var(--text-muted); cursor:pointer; transition:all 0.2s; }
        .topbar-btn:hover { color:var(--text); border-color:var(--primary); }
        .admin-avatar { width:38px; height:38px; background:linear-gradient(135deg,var(--primary),var(--accent)); border-radius:50%; display:flex; align-items:center; justify-content:center; font-weight:700; font-size:14px; }
        .content { padding:32px; flex:1; }

        /* Flash */
        .flash-success { background:rgba(16,185,129,0.1); border:1px solid rgba(16,185,129,0.3); color:#6ee7b7; border-radius:12px; padding:14px 20px; margin-bottom:20px; display:flex; align-items:center; gap:10px; font-size:14px; }
        .flash-error   { background:rgba(239,68,68,0.1);  border:1px solid rgba(239,68,68,0.3);  color:#fca5a5; border-radius:12px; padding:14px 20px; margin-bottom:20px; display:flex; align-items:center; gap:10px; font-size:14px; }

        /* Filter */
        .filter-bar { display:flex; align-items:center; gap:10px; margin-bottom:24px; flex-wrap:wrap; }
        .filter-btn { padding:7px 16px; border-radius:20px; border:1px solid var(--border); background:transparent; color:var(--text-muted); font-size:13px; font-weight:500; cursor:pointer; transition:all 0.2s; text-decoration:none; }
        .filter-btn:hover, .filter-btn.active { background:var(--primary); border-color:var(--primary); color:#fff; }
        .search-wrap { position:relative; margin-left:auto; }
        .search-wrap i { position:absolute; left:12px; top:50%; transform:translateY(-50%); color:var(--text-muted); font-size:13px; pointer-events:none; }
        .search-input { background:var(--surface); border:1px solid var(--border); border-radius:10px; padding:8px 14px 8px 36px; color:var(--text); font-size:13px; outline:none; width:240px; transition:border-color 0.2s; }
        .search-input:focus { border-color:var(--primary); }

        /* Card / Table */
        .card { background:var(--surface); border:1px solid var(--border); border-radius:16px; overflow:hidden; }
        .orders-table { width:100%; border-collapse:collapse; }
        .orders-table th { padding:12px 16px; font-size:11px; font-weight:600; letter-spacing:1px; text-transform:uppercase; color:var(--text-muted); text-align:left; background:var(--surface2); }
        .orders-table td { padding:14px 16px; font-size:14px; border-bottom:1px solid var(--border); vertical-align:middle; }
        .orders-table tr:last-child td { border-bottom:none; }
        .orders-table tr:hover td { background:rgba(255,255,255,0.02); }
        .order-id { font-size:12px; color:var(--primary-light); font-weight:600; font-family:monospace; }
        .customer-info { display:flex; align-items:center; gap:10px; }
        .customer-avatar { width:32px; height:32px; border-radius:50%; background:linear-gradient(135deg,var(--primary-dark),var(--accent)); display:flex; align-items:center; justify-content:center; font-size:12px; font-weight:700; flex-shrink:0; }
        .customer-name { font-weight:500; font-size:14px; }
        .customer-email { font-size:12px; color:var(--text-muted); }
        .amount { font-weight:600; color:var(--primary-light); }

        /* Status */
        .status { display:inline-flex; align-items:center; gap:5px; padding:4px 10px; border-radius:20px; font-size:12px; font-weight:600; }
        .status::before { content:''; width:6px; height:6px; border-radius:50%; }
        .status-beklemede  { background:rgba(245,158,11,0.15); color:#fcd34d; }
        .status-beklemede::before { background:#fcd34d; }
        .status-onaylandi  { background:rgba(16,185,129,0.15); color:#6ee7b7; }
        .status-onaylandi::before { background:#6ee7b7; }
        .status-kargoda    { background:rgba(59,130,246,0.15); color:#93c5fd; }
        .status-kargoda::before { background:#93c5fd; }
        .status-reddedildi { background:rgba(239,68,68,0.15); color:#fca5a5; }
        .status-reddedildi::before { background:#fca5a5; }
        .status-teslim     { background:rgba(192,38,211,0.15); color:var(--primary-light); }
        .status-teslim::before { background:var(--primary-light); }

        /* Action Buttons */
        .action-btns { display:flex; gap:6px; }
        .btn-action { width:30px; height:30px; border:none; border-radius:8px; cursor:pointer; display:flex; align-items:center; justify-content:center; font-size:13px; transition:all 0.2s; text-decoration:none; }
        .btn-approve { background:rgba(16,185,129,0.15); color:#6ee7b7; }
        .btn-approve:hover { background:var(--success); color:#fff; }
        .btn-reject  { background:rgba(239,68,68,0.15);  color:#fca5a5; }
        .btn-reject:hover  { background:var(--danger); color:#fff; }
        .btn-view    { background:rgba(59,130,246,0.15);  color:#93c5fd; }
        .btn-view:hover    { background:var(--info); color:#fff; }

        /* Pagination */
        .pagination-wrap { padding:20px 24px; display:flex; justify-content:flex-end; border-top:1px solid var(--border); }
        .pagination-wrap .page-link { display:inline-flex; align-items:center; justify-content:center; width:34px; height:34px; border-radius:8px; background:var(--surface2); border:1px solid var(--border); color:var(--text-muted); text-decoration:none; font-size:13px; margin:0 2px; transition:all 0.2s; }
        .pagination-wrap .page-link:hover, .pagination-wrap .page-link.active { background:var(--primary); border-color:var(--primary); color:#fff; }

        /* Status select */
        .status-select { background:var(--surface2); border:1px solid var(--border); border-radius:8px; color:var(--text); padding:5px 10px; font-size:12px; cursor:pointer; outline:none; }
        .status-select:focus { border-color:var(--primary); }
    </style>
</head>
<body>

<aside class="sidebar">
    <div class="sidebar-logo">
        <div class="icon">👗</div>
        <span>Kadın Giyim</span>
    </div>
    <nav class="sidebar-nav">
        <div class="nav-label">Genel</div>
        <a href="{{ route('admin.dashboard') }}" class="nav-item">
            <i class="fas fa-chart-pie"></i> Dashboard
        </a>
        <div class="nav-label" style="margin-top:12px">Mağaza</div>
        <a href="{{ route('admin.orders.index') }}" class="nav-item active">
            <i class="fas fa-shopping-bag"></i> Siparişler
        </a>
        <a href="{{ route('admin.products.index') }}" class="nav-item">
            <i class="fas fa-tshirt"></i> Ürünler
        </a>
        <a href="{{ route('admin.categories.index') }}" class="nav-item">
            <i class="fas fa-tags"></i> Kategoriler
        </a>
        <a href="#" class="nav-item">
            <i class="fas fa-users"></i> Müşteriler
        </a>
    </nav>
    <div class="sidebar-footer">
        <form action="{{ route('admin.logout') }}" method="POST">
            @csrf
            <button type="submit" class="nav-item" style="width:100%;border:none;background:transparent;cursor:pointer;">
                <i class="fas fa-sign-out-alt"></i> Çıkış Yap
            </button>
        </form>
    </div>
</aside>

<div class="main">
    <header class="topbar">
        <h1>Siparişler</h1>
        <div class="topbar-right">
            <div class="topbar-btn"><i class="fas fa-bell"></i></div>
            <div class="admin-avatar">A</div>
        </div>
    </header>

    <div class="content">

        @if(session('success'))
            <div class="flash-success"><i class="fas fa-check-circle"></i> {{ session('success') }}</div>
        @endif
        @if(session('error'))
            <div class="flash-error"><i class="fas fa-exclamation-circle"></i> {{ session('error') }}</div>
        @endif

        {{-- Filtreler --}}
        <div class="filter-bar">
            <a href="{{ route('admin.orders.index') }}"
               class="filter-btn {{ !request('status') ? 'active' : '' }}">Tümü</a>
            @foreach(['beklemede'=>'Beklemede','onaylandi'=>'Onaylandı','kargoda'=>'Kargoda','teslim edildi'=>'Teslim','reddedildi'=>'Reddedildi'] as $val=>$label)
            <a href="{{ route('admin.orders.index', ['status'=>$val]) }}"
               class="filter-btn {{ request('status')==$val ? 'active' : '' }}">{{ $label }}</a>
            @endforeach
            <div class="search-wrap">
                <i class="fas fa-search"></i>
                <form method="GET" action="{{ route('admin.orders.index') }}" style="display:inline">
                    <input type="hidden" name="status" value="{{ request('status') }}">
                    <input type="text" name="search" value="{{ request('search') }}"
                           class="search-input" placeholder="Sipariş / müşteri ara...">
                </form>
            </div>
        </div>

        {{-- Tablo --}}
        <div class="card">
            <table class="orders-table">
                <thead>
                    <tr>
                        <th>Sipariş No</th>
                        <th>Müşteri</th>
                        <th>Ürünler</th>
                        <th>Tutar</th>
                        <th>Durum</th>
                        <th>Tarih</th>
                        <th>İşlem</th>
                    </tr>
                </thead>
                <tbody>
                @forelse($orders as $order)
                    @php
                        $sMap = ['beklemede'=>'beklemede','onaylandi'=>'onaylandi','kargoda'=>'kargoda','reddedildi'=>'reddedildi','teslim edildi'=>'teslim'];
                        $sc = $sMap[strtolower($order->status ?? 'beklemede')] ?? 'beklemede';
                    @endphp
                    <tr>
                        <td><span class="order-id">#{{ strtoupper(substr($order->order_number ?? $order->id, 0, 12)) }}</span></td>
                        <td>
                            <div class="customer-info">
                                <div class="customer-avatar">{{ strtoupper(substr($order->user->name ?? 'M', 0, 1)) }}</div>
                                <div>
                                    <div class="customer-name">{{ $order->user->name ?? 'Misafir' }}</div>
                                    <div class="customer-email">{{ $order->user->email ?? '' }}</div>
                                </div>
                            </div>
                        </td>
                        <td style="font-size:12px;color:var(--text-muted);max-width:180px">
                            {{ $order->orderItems->take(2)->map(fn($i) => $i->product->name ?? '?')->join(', ') }}
                            @if($order->orderItems->count() > 2)
                                +{{ $order->orderItems->count() - 2 }} daha
                            @endif
                        </td>
                        <td><span class="amount">{{ number_format($order->total_price ?? 0, 2, ',', '.') }}₺</span></td>
                        <td><span class="status status-{{ $sc }}">{{ ucfirst($order->status ?? 'Beklemede') }}</span></td>
                        <td style="font-size:13px;color:var(--text-muted)">
                            {{ \Carbon\Carbon::parse($order->created_at)->format('d.m.Y H:i') }}
                        </td>
                        <td>
                            <div class="action-btns">
                                @if(in_array(strtolower($order->status ?? ''), ['beklemede','pending']))
                                <form action="{{ route('admin.orders.approve', $order->id) }}" method="POST" style="display:inline">
                                    @csrf @method('PATCH')
                                    <button type="submit" class="btn-action btn-approve" title="Onayla"
                                        onclick="return confirm('Siparişi onaylamak istiyor musunuz?')">
                                        <i class="fas fa-check"></i>
                                    </button>
                                </form>
                                <form action="{{ route('admin.orders.reject', $order->id) }}" method="POST" style="display:inline">
                                    @csrf @method('PATCH')
                                    <button type="submit" class="btn-action btn-reject" title="Reddet"
                                        onclick="return confirm('Siparişi reddetmek istiyor musunuz?')">
                                        <i class="fas fa-times"></i>
                                    </button>
                                </form>
                                @endif
                                <a href="{{ route('admin.orders.show', $order->id) }}" class="btn-action btn-view" title="Detay">
                                    <i class="fas fa-eye"></i>
                                </a>
                            </div>
                        </td>
                    </tr>
                @empty
                    <tr>
                        <td colspan="7" style="text-align:center;padding:48px;color:var(--text-muted)">
                            <i class="fas fa-inbox" style="font-size:32px;margin-bottom:12px;display:block;opacity:0.4"></i>
                            Sipariş bulunamadı.
                        </td>
                    </tr>
                @endforelse
                </tbody>
            </table>

            {{-- Pagination --}}
            @if($orders->hasPages())
            <div class="pagination-wrap">
                {{ $orders->appends(request()->query())->links() }}
            </div>
            @endif
        </div>

    </div>
</div>

</body>
</html>