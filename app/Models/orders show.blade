<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Sipariş Detayı – Admin</title>
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@600;700&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
    <style>
        :root {
            --primary:#c026d3; --primary-dark:#86198f; --primary-light:#f0abfc;
            --accent:#7c3aed; --bg:#0f0a1a; --surface:#1a1028; --surface2:#231535;
            --border:#2e1f42; --text:#f3e8ff; --text-muted:#a78bca;
            --success:#10b981; --danger:#ef4444; --warning:#f59e0b; --info:#3b82f6;
        }
        * { margin:0; padding:0; box-sizing:border-box; }
        body { font-family:'DM Sans',sans-serif; background:var(--bg); color:var(--text); display:flex; min-height:100vh; }

        .sidebar { width:260px; background:var(--surface); border-right:1px solid var(--border); position:fixed; top:0; left:0; height:100vh; z-index:100; display:flex; flex-direction:column; }
        .sidebar-logo { padding:28px 24px; border-bottom:1px solid var(--border); display:flex; align-items:center; gap:12px; }
        .sidebar-logo .icon { width:38px; height:38px; background:linear-gradient(135deg,var(--primary),var(--accent)); border-radius:10px; display:flex; align-items:center; justify-content:center; font-size:18px; }
        .sidebar-logo span { font-family:'Playfair Display',serif; font-size:17px; font-weight:700; background:linear-gradient(90deg,var(--primary-light),#e879f9); -webkit-background-clip:text; -webkit-text-fill-color:transparent; }
        .sidebar-nav { flex:1; padding:20px 12px; }
        .nav-label { font-size:10px; font-weight:600; letter-spacing:1.5px; text-transform:uppercase; color:var(--text-muted); padding:8px 12px 6px; }
        .nav-item { display:flex; align-items:center; gap:12px; padding:11px 14px; border-radius:10px; text-decoration:none; color:var(--text-muted); font-size:14px; font-weight:500; margin-bottom:3px; transition:all 0.2s; }
        .nav-item:hover { background:var(--surface2); color:var(--text); }
        .nav-item.active { background:linear-gradient(90deg,rgba(192,38,211,0.2),rgba(124,58,237,0.1)); color:var(--primary-light); border-left:3px solid var(--primary); }
        .nav-item i { width:18px; text-align:center; }
        .sidebar-footer { padding:16px 12px; border-top:1px solid var(--border); }

        .main { margin-left:260px; flex:1; }
        .topbar { background:var(--surface); border-bottom:1px solid var(--border); padding:16px 32px; display:flex; align-items:center; justify-content:space-between; position:sticky; top:0; z-index:90; }
        .topbar-left { display:flex; align-items:center; gap:16px; }
        .topbar-left h1 { font-family:'Playfair Display',serif; font-size:22px; font-weight:700; }
        .back-btn { display:inline-flex; align-items:center; gap:8px; padding:8px 16px; background:var(--surface2); border:1px solid var(--border); border-radius:10px; color:var(--text-muted); text-decoration:none; font-size:13px; font-weight:500; transition:all 0.2s; }
        .back-btn:hover { color:var(--text); border-color:var(--primary); }
        .topbar-right { display:flex; align-items:center; gap:12px; }
        .admin-avatar { width:38px; height:38px; background:linear-gradient(135deg,var(--primary),var(--accent)); border-radius:50%; display:flex; align-items:center; justify-content:center; font-weight:700; font-size:14px; }
        .content { padding:32px; }

        /* Flash */
        .flash-success { background:rgba(16,185,129,0.1); border:1px solid rgba(16,185,129,0.3); color:#6ee7b7; border-radius:12px; padding:14px 20px; margin-bottom:20px; display:flex; align-items:center; gap:10px; font-size:14px; }
        .flash-error   { background:rgba(239,68,68,0.1);  border:1px solid rgba(239,68,68,0.3);  color:#fca5a5; border-radius:12px; padding:14px 20px; margin-bottom:20px; display:flex; align-items:center; gap:10px; font-size:14px; }

        /* Layout */
        .detail-grid { display:grid; grid-template-columns:1fr 340px; gap:24px; }

        /* Card */
        .card { background:var(--surface); border:1px solid var(--border); border-radius:16px; overflow:hidden; margin-bottom:24px; }
        .card-header { padding:20px 24px; border-bottom:1px solid var(--border); display:flex; align-items:center; justify-content:space-between; }
        .card-header h2 { font-family:'Playfair Display',serif; font-size:16px; font-weight:700; }
        .card-body { padding:24px; }

        /* Order items table */
        .items-table { width:100%; border-collapse:collapse; }
        .items-table th { padding:10px 12px; font-size:11px; font-weight:600; letter-spacing:1px; text-transform:uppercase; color:var(--text-muted); text-align:left; background:var(--surface2); }
        .items-table td { padding:14px 12px; font-size:14px; border-bottom:1px solid var(--border); vertical-align:middle; }
        .items-table tr:last-child td { border-bottom:none; }
        .product-img { width:44px; height:44px; border-radius:10px; background:var(--surface2); object-fit:cover; border:1px solid var(--border); }

        /* Info rows */
        .info-row { display:flex; justify-content:space-between; align-items:center; padding:12px 0; border-bottom:1px solid var(--border); font-size:14px; }
        .info-row:last-child { border-bottom:none; }
        .info-label { color:var(--text-muted); }
        .info-value { font-weight:500; }

        /* Status */
        .status { display:inline-flex; align-items:center; gap:5px; padding:4px 12px; border-radius:20px; font-size:12px; font-weight:600; }
        .status::before { content:''; width:6px; height:6px; border-radius:50%; }
        .status-beklemede  { background:rgba(245,158,11,0.15); color:#fcd34d; }
        .status-beklemede::before { background:#fcd34d; }
        .status-onaylandi  { background:rgba(16,185,129,0.15); color:#6ee7b7; }
        .status-onaylandi::before { background:#6ee7b7; }
        .status-kargoda    { background:rgba(59,130,246,0.15); color:#93c5fd; }
        .status-kargoda::before { background:#93c5fd; }
        .status-reddedildi { background:rgba(239,68,68,0.15); color:#fca5a5; }
        .status-reddedildi::before { background:#fca5a5; }
        .status-teslim     { background:rgba(192,38,211,0.15); color:var(--primary-light); }
        .status-teslim::before { background:var(--primary-light); }

        /* Buttons */
        .btn { display:inline-flex; align-items:center; gap:8px; padding:10px 20px; border-radius:10px; font-size:14px; font-weight:500; cursor:pointer; border:none; transition:all 0.2s; }
        .btn-success { background:rgba(16,185,129,0.15); color:#6ee7b7; border:1px solid rgba(16,185,129,0.3); }
        .btn-success:hover { background:var(--success); color:#fff; }
        .btn-danger  { background:rgba(239,68,68,0.15);  color:#fca5a5; border:1px solid rgba(239,68,68,0.3); }
        .btn-danger:hover  { background:var(--danger); color:#fff; }
        .btn-group { display:flex; gap:10px; }

        /* Status form */
        .status-select { background:var(--surface2); border:1px solid var(--border); border-radius:10px; color:var(--text); padding:10px 14px; font-size:14px; cursor:pointer; outline:none; width:100%; margin-bottom:12px; }
        .status-select:focus { border-color:var(--primary); }
        .btn-full { width:100%; justify-content:center; background:linear-gradient(90deg,var(--primary),var(--accent)); color:#fff; border:none; }
        .btn-full:hover { opacity:0.9; }

        /* Total */
        .total-row { display:flex; justify-content:space-between; font-size:18px; font-weight:700; padding-top:16px; border-top:1px solid var(--border); color:var(--primary-light); }
    </style>
</head>
<body>

<aside class="sidebar">
    <div class="sidebar-logo">
        <div class="icon">👗</div>
        <span>Kadın Giyim</span>
    </div>
    <nav class="sidebar-nav">
        <div class="nav-label">Genel</div>
        <a href="{{ route('admin.dashboard') }}" class="nav-item"><i class="fas fa-chart-pie"></i> Dashboard</a>
        <div class="nav-label" style="margin-top:12px">Mağaza</div>
        <a href="{{ route('admin.orders.index') }}" class="nav-item active"><i class="fas fa-shopping-bag"></i> Siparişler</a>
        <a href="{{ route('admin.products.index') }}" class="nav-item"><i class="fas fa-tshirt"></i> Ürünler</a>
        <a href="{{ route('admin.categories.index') }}" class="nav-item"><i class="fas fa-tags"></i> Kategoriler</a>
        <a href="#" class="nav-item"><i class="fas fa-users"></i> Müşteriler</a>
    </nav>
    <div class="sidebar-footer">
        <form action="{{ route('admin.logout') }}" method="POST">
            @csrf
            <button type="submit" class="nav-item" style="width:100%;border:none;background:transparent;cursor:pointer;">
                <i class="fas fa-sign-out-alt"></i> Çıkış Yap
            </button>
        </form>
    </div>
</aside>

<div class="main">
    <header class="topbar">
        <div class="topbar-left">
            <a href="{{ route('admin.orders.index') }}" class="back-btn">
                <i class="fas fa-arrow-left"></i> Siparişler
            </a>
            <h1>Sipariş Detayı</h1>
        </div>
        <div class="topbar-right">
            <div class="admin-avatar">A</div>
        </div>
    </header>

    <div class="content">

        @if(session('success'))
            <div class="flash-success"><i class="fas fa-check-circle"></i> {{ session('success') }}</div>
        @endif
        @if(session('error'))
            <div class="flash-error"><i class="fas fa-exclamation-circle"></i> {{ session('error') }}</div>
        @endif

        <div class="detail-grid">

            {{-- Sol: Ürünler + Müşteri --}}
            <div>
                {{-- Sipariş Ürünleri --}}
                <div class="card">
                    <div class="card-header">
                        <h2>Sipariş Ürünleri</h2>
                        <span style="font-size:13px;color:var(--text-muted)">
                            #{{ strtoupper(substr($order->order_number ?? $order->id, 0, 12)) }}
                        </span>
                    </div>
                    <table class="items-table">
                        <thead>
                            <tr>
                                <th>Ürün</th>
                                <th>Beden</th>
                                <th>Adet</th>
                                <th>Birim Fiyat</th>
                                <th>Toplam</th>
                            </tr>
                        </thead>
                        <tbody>
                        @foreach($order->orderItems as $item)
                            <tr>
                                <td>
                                    <div style="display:flex;align-items:center;gap:12px">
                                        @if($item->product && $item->product->image)
                                            <img src="{{ asset('storage/' . $item->product->image) }}"
                                                 class="product-img" alt="{{ $item->product->name }}">
                                        @else
                                            <div class="product-img" style="display:flex;align-items:center;justify-content:center;font-size:20px">👗</div>
                                        @endif
                                        <span style="font-weight:500">{{ $item->product->name ?? 'Silinmiş Ürün' }}</span>
                                    </div>
                                </td>
                                <td style="color:var(--text-muted)">{{ $item->size ?? '—' }}</td>
                                <td>{{ $item->quantity }}</td>
                                <td>{{ number_format($item->price ?? 0, 2, ',', '.') }}₺</td>
                                <td style="font-weight:600;color:var(--primary-light)">
                                    {{ number_format(($item->price ?? 0) * $item->quantity, 2, ',', '.') }}₺
                                </td>
                            </tr>
                        @endforeach
                        </tbody>
                    </table>
                    <div style="padding:20px 24px">
                        <div class="total-row">
                            <span>Toplam</span>
                            <span>{{ number_format($order->total_price ?? 0, 2, ',', '.') }}₺</span>
                        </div>
                    </div>
                </div>

                {{-- Teslimat Adresi --}}
                @if($order->address ?? $order->shipping_address ?? null)
                <div class="card">
                    <div class="card-header"><h2><i class="fas fa-map-marker-alt" style="color:var(--primary);margin-right:8px"></i>Teslimat Adresi</h2></div>
                    <div class="card-body">
                        <p style="font-size:14px;line-height:1.7;color:var(--text-muted)">
                            {{ $order->address ?? $order->shipping_address }}
                        </p>
                    </div>
                </div>
                @endif
            </div>

            {{-- Sağ: Durum + Müşteri --}}
            <div>
                {{-- Sipariş Bilgileri --}}
                <div class="card" style="margin-bottom:24px">
                    <div class="card-header"><h2>Sipariş Bilgileri</h2></div>
                    <div class="card-body">
                        @php
                            $sMap = ['beklemede'=>'beklemede','onaylandi'=>'onaylandi','kargoda'=>'kargoda','reddedildi'=>'reddedildi','teslim edildi'=>'teslim'];
                            $sc = $sMap[strtolower($order->status ?? 'beklemede')] ?? 'beklemede';
                        @endphp
                        <div class="info-row">
                            <span class="info-label">Durum</span>
                            <span class="status status-{{ $sc }}">{{ ucfirst($order->status ?? 'Beklemede') }}</span>
                        </div>
                        <div class="info-row">
                            <span class="info-label">Sipariş No</span>
                            <span class="info-value" style="font-family:monospace;font-size:12px">#{{ strtoupper($order->order_number ?? $order->id) }}</span>
                        </div>
                        <div class="info-row">
                            <span class="info-label">Tarih</span>
                            <span class="info-value">{{ \Carbon\Carbon::parse($order->created_at)->format('d.m.Y H:i') }}</span>
                        </div>
                        <div class="info-row">
                            <span class="info-label">Ödeme</span>
                            <span class="info-value">{{ $order->payment_method ?? 'Kredi Kartı' }}</span>
                        </div>

                        {{-- Onayla / Reddet --}}
                        @if(in_array(strtolower($order->status ?? ''), ['beklemede','pending']))
                        <div class="btn-group" style="margin-top:20px">
                            <form action="{{ route('admin.orders.approve', $order->id) }}" method="POST" style="flex:1">
                                @csrf @method('PATCH')
                                <button type="submit" class="btn btn-success" style="width:100%;justify-content:center"
                                    onclick="return confirm('Siparişi onaylamak istiyor musunuz?')">
                                    <i class="fas fa-check"></i> Onayla
                                </button>
                            </form>
                            <form action="{{ route('admin.orders.reject', $order->id) }}" method="POST" style="flex:1">
                                @csrf @method('PATCH')
                                <button type="submit" class="btn btn-danger" style="width:100%;justify-content:center"
                                    onclick="return confirm('Siparişi reddetmek istiyor musunuz?')">
                                    <i class="fas fa-times"></i> Reddet
                                </button>
                            </form>
                        </div>
                        @endif
                    </div>
                </div>

                {{-- Durum Güncelle --}}
                <div class="card" style="margin-bottom:24px">
                    <div class="card-header"><h2>Durumu Güncelle</h2></div>
                    <div class="card-body">
                        <form action="{{ route('admin.orders.status', $order->id) }}" method="POST">
                            @csrf @method('PATCH')
                            <select name="status" class="status-select">
                                @foreach(['beklemede'=>'Beklemede','onaylandi'=>'Onaylandı','kargoda'=>'Kargoda','teslim edildi'=>'Teslim Edildi','reddedildi'=>'Reddedildi'] as $val=>$label)
                                    <option value="{{ $val }}" {{ $order->status == $val ? 'selected' : '' }}>{{ $label }}</option>
                                @endforeach
                            </select>
                            <button type="submit" class="btn btn-full">
                                <i class="fas fa-sync-alt"></i> Güncelle
                            </button>
                        </form>
                    </div>
                </div>

                {{-- Müşteri --}}
                <div class="card">
                    <div class="card-header"><h2>Müşteri</h2></div>
                    <div class="card-body">
                        <div style="display:flex;align-items:center;gap:14px;margin-bottom:16px">
                            <div style="width:46px;height:46px;border-radius:50%;background:linear-gradient(135deg,var(--primary-dark),var(--accent));display:flex;align-items:center;justify-content:center;font-size:18px;font-weight:700">
                                {{ strtoupper(substr($order->user->name ?? 'M', 0, 1)) }}
                            </div>
                            <div>
                                <div style="font-weight:600;font-size:15px">{{ $order->user->name ?? 'Misafir' }}</div>
                                <div style="font-size:12px;color:var(--text-muted)">{{ $order->user->email ?? '' }}</div>
                            </div>
                        </div>
                        @if($order->user)
                        <div class="info-row">
                            <span class="info-label">Toplam Sipariş</span>
                            <span class="info-value">{{ $order->user->orders->count() }}</span>
                        </div>
                        <div class="info-row">
                            <span class="info-label">Kayıt Tarihi</span>
                            <span class="info-value">{{ \Carbon\Carbon::parse($order->user->created_at)->format('d.m.Y') }}</span>
                        </div>
                        @endif
                    </div>
                </div>

            </div>
        </div>
    </div>
</div>

</body>
</html>