<style>
@import url('https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,500;0,700;1,400;1,500&family=Didact+Gothic&display=swap');

:root {
    --ink:   #1a1410;
    --cream: #f7f3ee;
    --sand:  #e8e0d5;
    --gold:  #c9a96e;
    --gold2: #e8c98a;
    --rouge: #9b4a5a;
    --smoke: #6b6560;
}

.db-shell { min-height:100vh; background:var(--cream); font-family:'Didact Gothic',sans-serif; }

.db-banner { background:var(--ink); padding:3.5rem 3rem 0; position:relative; overflow:hidden; animation:fadeIn .5s ease; }
.db-banner::before { content:''; position:absolute; inset:0; background: radial-gradient(ellipse 60% 80% at 80% 50%,rgba(201,169,110,.12) 0%,transparent 70%), radial-gradient(ellipse 40% 60% at 10% 80%,rgba(155,74,90,.10) 0%,transparent 60%); }
.db-banner-inner { max-width:1200px; margin:0 auto; position:relative; z-index:1; display:flex; align-items:flex-end; justify-content:space-between; gap:2rem; }
.db-greeting-eyebrow { font-family:'Didact Gothic',sans-serif; font-size:.65rem; letter-spacing:4px; text-transform:uppercase; color:var(--gold); margin-bottom:.6rem; }
.db-greeting-name { font-family:'Playfair Display',serif; font-size:clamp(2rem,4vw,3.2rem); font-weight:400; font-style:italic; color:#f0ebe3; line-height:1.1; margin:0 0 .4rem; }
.db-greeting-sub { font-size:.78rem; color:rgba(240,235,227,.45); letter-spacing:1.5px; margin-bottom:2.5rem; }
.db-date-tag { flex-shrink:0; text-align:right; padding-bottom:2.5rem; }
.db-date-day { font-family:'Playfair Display',serif; font-size:3.5rem; font-weight:700; color:rgba(201,169,110,.2); line-height:1; }
.db-date-label { font-size:.65rem; letter-spacing:3px; color:rgba(240,235,227,.3); text-transform:uppercase; }

.db-stats-strip { background:var(--ink); padding:0 3rem; animation:fadeIn .5s ease; }
.db-stats-inner { max-width:1200px; margin:0 auto; border-top:1px solid rgba(201,169,110,.18); display:grid; grid-template-columns:repeat(3,1fr); }
.db-stat { padding:2rem 1.5rem; border-right:1px solid rgba(201,169,110,.10); position:relative; transition:background .3s; }
.db-stat:last-child { border-right:none; }
.db-stat:hover { background:rgba(201,169,110,.05); }
.db-stat-label { font-size:.6rem; letter-spacing:3px; text-transform:uppercase; color:rgba(240,235,227,.35); margin-bottom:.6rem; }
.db-stat-value { font-family:'Playfair Display',serif; font-size:2.6rem; font-weight:400; color:#f0ebe3; line-height:1; margin-bottom:.3rem; }
.db-stat-value span { font-size:1rem; color:var(--gold); font-family:'Didact Gothic',sans-serif; margin-left:2px; }
.db-stat-sub { font-size:.65rem; color:rgba(240,235,227,.3); letter-spacing:1px; }
.db-stat-icon { position:absolute; top:1.8rem; right:1.5rem; opacity:.08; }

.db-body { max-width:1200px; margin:0 auto; padding:2.5rem 3rem; display:grid; grid-template-columns:1fr 1.2fr; gap:1.5rem; align-items:start; }
.db-section-head { display:flex; align-items:baseline; gap:1rem; margin-bottom:1.2rem; }
.db-section-title { font-family:'Playfair Display',serif; font-size:1.15rem; font-weight:500; color:var(--ink); }
.db-section-line { flex:1; height:1px; background:var(--sand); }

.db-quick-card, .db-orders-card { background:#fff; border:1px solid var(--sand); }
.db-quick-card { animation:fadeSlide .5s ease .1s both; }
.db-orders-card { animation:fadeSlide .5s ease .2s both; }

.db-nav-item { display:flex; align-items:center; gap:1.2rem; padding:1.1rem 1.5rem; border-bottom:1px solid #f5f1ec; text-decoration:none; transition:all .2s; position:relative; overflow:hidden; }
.db-nav-item:last-child { border-bottom:none; }
.db-nav-item::before { content:''; position:absolute; left:0; top:0; bottom:0; width:2px; background:var(--gold); transform:scaleY(0); transition:transform .2s; }
.db-nav-item:hover { background:#faf8f5; }
.db-nav-item:hover::before { transform:scaleY(1); }
.db-nav-icon { width:36px; height:36px; border:1px solid var(--sand); display:flex; align-items:center; justify-content:center; flex-shrink:0; transition:all .2s; }
.db-nav-item:hover .db-nav-icon { border-color:var(--gold); background:rgba(201,169,110,.06); }
.db-nav-name { font-size:.82rem; font-weight:500; color:var(--ink); letter-spacing:.5px; display:block; }
.db-nav-desc { font-size:.68rem; color:var(--smoke); margin-top:1px; }
.db-nav-arrow { color:#ccc; transition:transform .2s,color .2s; }
.db-nav-item:hover .db-nav-arrow { transform:translateX(3px); color:var(--gold); }

.db-order-item { padding:1.2rem 1.5rem; border-bottom:1px solid #f5f1ec; text-decoration:none; display:block; transition:background .2s; }
.db-order-item:last-child { border-bottom:none; }
.db-order-item:hover { background:#faf8f5; }
.db-order-row { display:flex; align-items:center; justify-content:space-between; margin-bottom:.4rem; }
.db-order-id { font-family:'Playfair Display',serif; font-size:.85rem; font-style:italic; color:var(--ink); }
.db-order-amount { font-size:.9rem; font-weight:500; color:var(--rouge); letter-spacing:.5px; }
.db-order-meta { display:flex; align-items:center; justify-content:space-between; }
.db-order-date { font-size:.65rem; color:var(--smoke); letter-spacing:1.5px; text-transform:uppercase; }
.db-status { font-size:.6rem; letter-spacing:2px; text-transform:uppercase; padding:.2rem .7rem; border:1px solid; }
.db-status.delivered { color:#5a8a6a; border-color:#5a8a6a; background:rgba(90,138,106,.06); }
.db-status.pending   { color:var(--gold); border-color:var(--gold); background:rgba(201,169,110,.06); }

.db-empty { padding:3rem 2rem; text-align:center; }
.db-empty-title { font-family:'Playfair Display',serif; font-size:1rem; font-style:italic; color:var(--smoke); margin-bottom:.5rem; }
.db-empty-sub { font-size:.72rem; color:#bbb; letter-spacing:1px; margin-bottom:1.5rem; }
.db-empty-btn { display:inline-block; background:var(--ink); color:#f0ebe3; font-size:.68rem; letter-spacing:3px; text-transform:uppercase; padding:.75rem 1.8rem; text-decoration:none; transition:background .2s; }
.db-empty-btn:hover { background:var(--rouge); }

.db-profile-strip { grid-column:1/-1; background:var(--ink); display:flex; align-items:center; justify-content:space-between; padding:1.5rem 2rem; gap:2rem; animation:fadeSlide .5s ease .3s both; }
.db-profile-left { display:flex; align-items:center; gap:1.2rem; }
.db-profile-avatar { width:48px; height:48px; border:1px solid rgba(201,169,110,.4); display:flex; align-items:center; justify-content:center; font-family:'Playfair Display',serif; font-size:1.2rem; font-style:italic; color:var(--gold); flex-shrink:0; }
.db-profile-name { font-family:'Playfair Display',serif; font-size:1rem; font-style:italic; color:#f0ebe3; }
.db-profile-email { font-size:.65rem; color:rgba(240,235,227,.35); letter-spacing:1.5px; margin-top:2px; }
.db-profile-actions { display:flex; gap:.8rem; }
.db-profile-btn { font-size:.65rem; letter-spacing:2.5px; text-transform:uppercase; padding:.6rem 1.4rem; text-decoration:none; border:1px solid; transition:all .2s; }
.db-profile-btn.outline { color:rgba(240,235,227,.5); border-color:rgba(240,235,227,.15); }
.db-profile-btn.outline:hover { color:var(--gold); border-color:var(--gold); }
.db-profile-btn.solid { color:var(--ink); background:var(--gold); border-color:var(--gold); }
.db-profile-btn.solid:hover { background:var(--gold2); border-color:var(--gold2); }

@keyframes fadeIn    { from{opacity:0} to{opacity:1} }
@keyframes fadeSlide { from{opacity:0;transform:translateY(14px)} to{opacity:1;transform:translateY(0)} }

@media(max-width:768px){
    .db-banner,.db-stats-strip{padding-left:1.5rem;padding-right:1.5rem;}
    .db-body{grid-template-columns:1fr;padding:1.5rem;}
    .db-stats-inner{grid-template-columns:1fr;}
    .db-stat{border-right:none;border-bottom:1px solid rgba(201,169,110,.10);}
    .db-date-tag{display:none;}
    .db-profile-strip{flex-direction:column;align-items:flex-start;grid-column:1;}
}
